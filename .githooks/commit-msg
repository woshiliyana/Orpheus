#!/usr/bin/env bash
set -euo pipefail
msg_file="$1"
subject=$(head -n 1 "$msg_file")

case "$subject" in
  feat:*|fix:*|docs:*|chore:*|test:*|refactor:* )
    exit 0
    ;;
  * )
    echo "Commit subject should use conventional prefix like feat:, fix:, docs:, chore:, test:, refactor:." >&2
    exit 2
    ;;
esac
