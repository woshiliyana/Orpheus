@@ -0,0 +1,24 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+repo_root=$(git rev-parse --show-toplevel)
+cd "$repo_root"
+
+staged_files=$(git diff --cached --name-only)
+[ -n "$staged_files" ] || exit 0
+
+branch=$(git rev-parse --abbrev-ref HEAD)
+
+if [ "$branch" = "main" ] && echo "$staged_files" | grep -E '^(src/|tests/|package.json|pnpm-lock.yaml)'; then
+  echo "Blocked: do not commit product code directly on main. Use a worktree branch." >&2
+  exit 2
+fi
+
+if echo "$staged_files" | grep -E '^(\.env($|\.)|secrets/|\.agent/|runs/|benchmark-results/)'; then
+  echo "Blocked: staged files include secrets or runtime artifacts." >&2
+  exit 2
+fi
+
+if [ "$branch" != "main" ]; then
+  python3 "$repo_root/scripts/lib/task_brief.py" assert-paths --require-brief $staged_files
+fi
diff --git a/.githooks/pre-push b/.githooks/pre-push
new file mode 100644
index 0000000..b80e393
--- /dev/null
+++ b/.githooks/pre-push
@@ -0,0 +1,19 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+repo_root=$(git rev-parse --show-toplevel)
+cd "$repo_root"
+
+pushing_main=false
+while read -r local_ref local_sha remote_ref remote_sha; do
+  [ -n "${local_ref:-}" ] || continue
+  if [ "$remote_ref" = "refs/heads/main" ] || [ "$remote_ref" = "refs/heads/master" ]; then
+    pushing_main=true
+  fi
+done
+
+python3 "$repo_root/scripts/lib/task_brief.py" assert-push-ready $( [ "$pushing_main" = true ] && printf '%s' '--pushing-main' )
+
+if [ "${ORPHEUS_SKIP_CHECKS:-0}" != "1" ]; then
+  "$repo_root/scripts/checks/run-required.sh"
+fi
