# Copy this file to .env.local and fill in real values there.
# .env.local is gitignored and should remain server-only.
# For one shared secret file across all worktrees of this repo, prefer:
#   .git/orpheus.server.env
# That path is project-scoped, not machine-global.

# Provider secrets: keep server-side only.
INWORLD_API_KEY=
CARTESIA_API_KEY=

# Provider tuning and cost assumptions.
INWORLD_RATE_USD_PER_1M_CHARS=30
INWORLD_MAX_ATTEMPTS=3
CARTESIA_API_VERSION=2026-03-01
CARTESIA_RATE_USD_PER_1M_CHARS=31.2
CARTESIA_MAX_ATTEMPTS=3

# Internal cost model knobs.
ALIGNMENT_COMPUTE_PER_AUDIO_MINUTE_USD=0.01
STORAGE_DELIVERY_PER_AUDIO_MINUTE_USD=0.002

# Future web-app validation boundary.
# TURNSTILE_SECRET_KEY must stay server-only.
# TURNSTILE_SITE_KEY is public-safe, but current CLI does not use it yet.
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
